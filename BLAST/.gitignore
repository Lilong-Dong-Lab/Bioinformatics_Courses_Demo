# pixi environments
.pixi/*
!.pixi/config.toml

# Python cache
__pycache__/
*.pyc

# BLAST database files (generated by makeblastdb)
*.pdb
*.phr
*.pin
*.psq
*.pjs
*.pot
*.pto
*.ptf

# Results directory (generated during execution)
results/*.txt
results/*.xml
results/*.csv

# Coverage reports
.coverage

# Parent results directory (generated)
results/
