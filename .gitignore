# Python
__pycache__/
*.py[cod]
*$py.class

# Pixi environment
.pixi/

# macOS Finder metadata
.DS_Store

# Analysis outputs (regenerated when the demos are run)
results/

# BLAST database index files (generated by makeblastdb)
# NOTE: *.pdb is deliberately NOT ignored globally — real Protein Data Bank
# structure files are tracked as source under pdb_query/data/,
# protein_ligand_docking_analysis/data/, and md_simulation_analysis/data/.
BLAST/**/*.phr
BLAST/**/*.pin
BLAST/**/*.psq
BLAST/**/*.pjs
BLAST/**/*.pot
BLAST/**/*.pto
BLAST/**/*.ptf
